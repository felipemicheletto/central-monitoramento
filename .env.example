# ============================================================================
# Variaveis de ambiente - copie este arquivo para ".env" e preencha os valores.
# Em producao (Render) configure essas variaveis no painel do servico.
# ============================================================================

# ---------- Portas ----------
# PORT       = porta HTTP usada pelo Render para healthcheck (Render injeta automaticamente)
# TCP_PORT   = porta TCP onde a central Vetti se conecta
# HOST       = bind address
PORT=10000
TCP_PORT=3013
HOST=0.0.0.0

# ---------- Log ----------
# LOG_FILE       = caminho do arquivo de log
# LOG_MAX_BYTES  = tamanho maximo (bytes) antes de enviar por email e limpar (300 KB)
LOG_FILE=eventos.log
LOG_MAX_BYTES=307200

# ---------- Pushover (notificacoes push) ----------
PUSHOVER_TOKEN=seu_token_pushover_aqui
PUSHOVER_USER=seu_user_pushover_aqui

# ---------- Email (Gmail com senha de app) ----------
# Crie uma "Senha de app" em https://myaccount.google.com/apppasswords
MAIL_USER=seu_email@gmail.com
MAIL_PASS=sua_senha_de_app
MAIL_FROM=central@monitoramento.com
MAIL_TO=destinatario@dominio.com

# Email para onde enviar o log rotacionado (opcional - padrao = MAIL_TO)
MAIL_LOG_TO=felyp20@hotmail.com

# ---------- Filtros de eventos (Contact-ID QEVT, separados por virgula) ----------
# Eventos ignorados (nao notificam)
EVENTS_IGNORE=1141,1602
# Eventos que disparam push de alta prioridade
EVENTS_ALERT=1130,3130,1309
# Eventos que disparam email
EVENTS_MAIL=1130,3130
